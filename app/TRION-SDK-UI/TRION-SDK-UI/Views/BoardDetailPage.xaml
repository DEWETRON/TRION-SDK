<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TRION_SDK_UI.BoardDetailPage"
             Title="{Binding Title}">
    <ScrollView>
        <VerticalStackLayout Padding="8" Spacing="8">
            <Label Text="{Binding Title}" FontSize="22" FontAttributes="Bold" />
            <BoxView HeightRequest="1" />

            <VerticalStackLayout Spacing="10">

                <!-- Operation Mode (picker - discrete values) -->
                <VerticalStackLayout IsVisible="{Binding OperationModes.Count}">
                    <Label Text="Operation Mode" FontAttributes="Bold" />
                    <Picker ItemsSource="{Binding OperationModes}"
                            SelectedItem="{Binding SelectedOperationMode, Mode=TwoWay}"
                            Title="Select mode" />
                </VerticalStackLayout>

                <!-- Sample Rate (free entry + quick picks) -->
                <VerticalStackLayout>
                    <Label Text="Sample Rate (Hz)" FontAttributes="Bold" />
                    <Entry Text="{Binding SampleRateText, Mode=TwoWay}"
                           Keyboard="Numeric"
                           Placeholder="Enter sample rate" />
                    <Label Text="{Binding SampleRateRangeHint}" 
                           FontSize="12" 
                           TextColor="Gray"
                           IsVisible="{Binding IsSampleRateProgrammable}" />
                    <Label Text="{Binding SampleRateError}" 
                           FontSize="12" 
                           TextColor="Red"
                           IsVisible="{Binding HasSampleRateError}" />
                </VerticalStackLayout>

                <!-- Sample Rate Divider (free entry + quick picks) -->
                <VerticalStackLayout IsVisible="{Binding HasSampleRateDivider}">
                    <Label Text="Sample Rate Divider" FontAttributes="Bold" />
                    <Entry Text="{Binding DividerText, Mode=TwoWay}"
                           Keyboard="Numeric"
                           Placeholder="Enter divider" />
                    <Label Text="{Binding DividerRangeHint}" 
                           FontSize="12" 
                           TextColor="Gray" />
                    <Label Text="{Binding DividerError}" 
                           FontSize="12" 
                           TextColor="Red"
                           IsVisible="{Binding HasDividerError}" />
                </VerticalStackLayout>

                <!-- External Trigger (picker) -->
                <VerticalStackLayout IsVisible="{Binding ExternalTriggerValues.Count}">
                    <Label Text="External Trigger" FontAttributes="Bold" />
                    <Picker ItemsSource="{Binding ExternalTriggerValues}"
                            SelectedItem="{Binding ExternalTrigger, Mode=TwoWay}"
                            Title="Select trigger" />
                </VerticalStackLayout>

                <!-- External Clock (picker) -->
                <VerticalStackLayout IsVisible="{Binding ExternalClockValues.Count}">
                    <Label Text="External Clock" FontAttributes="Bold" />
                    <Picker ItemsSource="{Binding ExternalClockValues}"
                            SelectedItem="{Binding ExternalClock, Mode=TwoWay}"
                            Title="Select clock" />
                </VerticalStackLayout>

                <VerticalStackLayout IsVisible="{Binding ResolutionAIValues.Count}">
                    <Label Text="Resolution AI" FontAttributes="Bold" />
                    <Picker ItemsSource="{Binding ResolutionAIValues}"
                            SelectedItem="{Binding ResolutionAI, Mode=TwoWay}"
                            Title="Select Analog to Digital Resolution" />
                </VerticalStackLayout>


            </VerticalStackLayout>

            <HorizontalStackLayout Spacing="12" Margin="0,10,0,0">
                <Button Text="Apply" Command="{Binding ApplyCommand}" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>